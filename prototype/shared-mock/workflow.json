        { "nodeId": "n3", "name": "总部审批", "type": "approval", "assigneeType": "role", "assignee": "head_office", "timeoutHours": 48, "conditions": [{ "field": "amount", "operator": ">", "value": 5000 }], "actions": { "approve": "__approved__", "reject": "__rejected__" } }
      ]
    },
