{
  "workflowDefs": [
    {
      "workflowId": "WF_PURCHASE",
      "name": "采购审批流程",
      "entityType": "PurchaseOrder",
      "entityLabel": "采购单",
      "description": "外部采购按金额自动路由审批：<500店长，500-5000店长+财务，>5000店长+财务+总部运营",
      "version": 1,
      "enabled": true,
      "contextHelp": "金额条件取采购单总金额（totalAmount），自动匹配首个满足条件的节点",
      "nodes": [
        { "nodeId": "n1", "name": "店长审批", "type": "approval", "assigneeType": "role", "assignee": "store_manager", "timeoutHours": 48,
          "conditions": [], "actions": { "approve": "n2", "reject": "__rejected__" } },
        { "nodeId": "n2", "name": "财务审批", "type": "approval", "assigneeType": "role", "assignee": "finance", "timeoutHours": 48,
          "conditions": [{ "field": "totalAmount", "operator": ">=", "value": 500 }], "actions": { "approve": "n3", "reject": "__rejected__" } },
        { "nodeId": "n3", "name": "总部运营审批", "type": "approval", "assigneeType": "role", "assignee": "head_office", "timeoutHours": 48,
          "conditions": [{ "field": "totalAmount", "operator": ">", "value": 5000 }], "actions": { "approve": "__approved__", "reject": "__rejected__" } }
      ]
    },
    {
      "workflowId": "WF_EXPENSE",
      "name": "支出审批流程",
      "entityType": "ExpenseOrder",
      "entityLabel": "支出单",
      "description": "请款/报销按金额路由：<500店长，500-5000店长+财务，>5000店长+财务+总部",
      "version": 1, "enabled": true,
      "nodes": [
        { "nodeId": "n1", "name": "店长审批", "type": "approval", "assigneeType": "role", "assignee": "store_manager", "timeoutHours": 48, "conditions": [], "actions": { "approve": "n2", "reject": "__rejected__" } },
