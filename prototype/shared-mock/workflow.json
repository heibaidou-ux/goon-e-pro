        { "nodeId": "n1", "name": "店长审批", "type": "approval", "assigneeType": "role", "assignee": "store_manager", "timeoutHours": 24, "conditions": [], "actions": { "approve": "__approved__", "reject": "__rejected__" } }
      ]
    },
