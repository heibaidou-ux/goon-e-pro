        <mxCell id="s7" value="" style="html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#6366F1;strokeWidth=2;endArrow=classic;endFill=1;" edge="1" source="hq" target="exp" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ====== 域间协作关系线 ====== -->
        <mxCell id="c1" value="协作" style="html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#94A3B8;strokeWidth=1;endArrow=classic;dashed=1;fontSize=9;" edge="1" source="mkt" target="ops" parent="1">
