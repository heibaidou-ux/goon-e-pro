        <mxCell id="s5" value="" style="html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#6366F1;strokeWidth=2;endArrow=classic;endFill=1;" edge="1" source="hq" target="hr" parent="1">
