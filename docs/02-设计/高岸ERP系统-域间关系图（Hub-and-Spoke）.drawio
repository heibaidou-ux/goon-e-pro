        <mxCell id="c5" value="人力成本" style="html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#94A3B8;strokeWidth=1;endArrow=classic;dashed=1;fontSize=9;" edge="1" source="hr" target="fin" parent="1">
