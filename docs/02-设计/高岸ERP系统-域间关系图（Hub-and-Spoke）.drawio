        <mxCell id="c6" value="设备控制" style="html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#94A3B8;strokeWidth=1;endArrow=classic;dashed=1;fontSize=9;" edge="1" source="tec" target="ops" parent="1">
