        <mxCell id="c7" value="拓展指令" style="html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#94A3B8;strokeWidth=1;endArrow=classic;dashed=1;fontSize=9;" edge="1" source="hq" target="exp" parent="1">
